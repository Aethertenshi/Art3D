{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Art3DC++ (MSBuild)",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\Art3DC++.vcxproj",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build using MSBuild (Visual Studio project)"
        }
    ]
}
